{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mentor Concurso",
  "version": "0.6.2",
  "identifier": "com.felipe.mentorconcurso",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mentor Concurso",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pheliperibeiro97-tech/mentor-concurso/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2ODdGNkYzQUJFQzM4MzgKUldRNE9PeXI4L2FITmc0MlRqdlVaVDhORWNVOU5GUzgySGZhTnV2QU5GY2twU2g1ZXFaeXcyWi8K",
      "windows": { "installMode": "passive" }
    }
  }
}
